POSTGRES_USER=
POSTGRES_PASSWORD=<TU_PASSWORD_DE_POSTGRES>
POSTGRES_DB=telemedicina

# Local Docker fallback by microservice:
AUTH_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/postgres?schema=auth
APPOINTMENT_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/postgres?schema=appointments
CLINICAL_HISTORY_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/postgres?schema=clinical_history
DATABASE_SSL=false

# Supabase production/staging example:
# AUTH_DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?schema=auth&pgbouncer=true
# APPOINTMENT_DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?schema=appointments&pgbouncer=true
# CLINICAL_HISTORY_DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?schema=clinical_history&pgbouncer=true
# DATABASE_SSL=true

JWT_SECRET=<TU_SECRETO_JWT_ALEATORIO_LARGO>
ENCRYPTION_KEY=<TU_LLAVE_DE_ENCRIPTACION_DE_32_BYTES>
DOCTOR_REGISTRATION_KEY=<TU_CLAVE_DE_REGISTRO_MEDICO>

FRONTEND_URL=http://localhost:5173

TWILIO_ACCOUNT_SID=
TWILIO_API_KEY=
TWILIO_API_SECRET=

STRIPE_SECRET_KEY=
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=<TU_PASSWORD_DE_PGADMIN>
