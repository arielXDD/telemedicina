datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  name          String
  role          String // "PACIENTE" o "MEDICO"
  specialty     String? // Especialidad médica (solo para médicos, ej: "Cardiología", "Pediatría")
  licenseNumber String? // Cédula Profesional (requerido para médicos)
  isApproved    Boolean  @default(true) // Aprobación administrativa (los médicos inician inactivos en el servicio)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
