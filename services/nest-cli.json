{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/services/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": false,
    "tsConfigPath": "apps/services/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/services",
  "projects": {
    "appointment-service": {
      "type": "application",
      "root": "apps/appointment-service",
      "entryFile": "main",
      "sourceRoot": "apps/appointment-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/appointment-service/tsconfig.app.json"
      }
    },
    "auth-service": {
      "type": "application",
      "root": "apps/auth-service",
      "entryFile": "main",
      "sourceRoot": "apps/auth-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth-service/tsconfig.app.json"
      }
    },
    "clinical-history-service": {
      "type": "application",
      "root": "apps/clinical-history-service",
      "entryFile": "clinical-history-service/src/main",
      "sourceRoot": "apps/clinical-history-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/clinical-history-service/tsconfig.app.json"
      }
    },
    "services": {
      "type": "application",
      "root": "apps/services",
      "entryFile": "main",
      "sourceRoot": "apps/services/src",
      "compilerOptions": {
        "tsConfigPath": "apps/services/tsconfig.app.json"
      }
    }
  }
}